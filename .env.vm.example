# Configuration type pour une VM Azure apres clone du repo
# Copiez ce fichier en .env.vm puis adaptez les valeurs necessaires.
#
# Mode recommande: VM = interface + orchestration, donnees centralisees dans Databricks.

# API exposee localement pour n8n sur la meme VM.
APP_HOST=127.0.0.1
APP_PORT=8000

# n8n appelle l'API avec une cle technique.
APP_REQUIRE_AUTH=true
ENABLE_PROFILE_LOGIN=true
APP_PROFILE_LOGIN_PASSWORD=change-me-in-vm
APP_API_KEYS=change-me-in-vm
APP_API_ACTOR=n8n
APP_API_ROLE=adv
SFTP_ENABLED=true
N8N_PROJECT_ROOT=

# Profil EDI verrouille
EDIFACT_PROFILE=ELM_STANDARD
EDIFACT_SYNTAX=D96A
UNB_SENDER_GLN=4399901876613
UNB_RECEIVER_GLN=3015981600108

# Stockage central Databricks (recommande)
MASTERDATA_SOURCE_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/masterdata/
MASTERDATA_RUNTIME_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/masterdata_runtime
OUTBOX_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/outbox
LOG_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/logs
PDF_STORAGE_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/pdf
INTAKE_DIR=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/pdf
DB_PATH=/Volumes/hcdap_prod/silver_hcfrdashlog/f2edi/database/edifact_standalone.db

# Option SQLite locale (decommenter uniquement pour debug local sur VM)
# MASTERDATA_RUNTIME_DIR=data/masterdata
# MASTERDATA_SOURCE_DIR=data/masterdata
# OUTBOX_DIR=data/outbox
# LOG_DIR=data/logs
# PDF_STORAGE_DIR=data/pdf
# INTAKE_DIR=data/pdf
# DB_PATH=data/edifact_standalone.db

# Auth UI optionnelle pour revue manuelle
APP_ADMIN_USERS=dik1dy@bosch.com,dik1dy,khadara

# LLM Databricks si la VM doit continuer a utiliser le meme endpoint d'extraction
DATABRICKS_CONFIG_PROFILE=Khadara
DATABRICKS_HOST=https://adb-5555213114570927.7.azuredatabricks.net
DATABRICKS_MODEL_ENDPOINT=databricks-gpt-oss-120b
DATABRICKS_WAREHOUSE_ID=607eec0346978542
EDIFACT_CATALOG=hcdap_prod
EDIFACT_SCHEMA=silver_hcfrdashlog

# SFTP cible SAP/Esker
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=
SFTP_PRIVATE_KEY_PASSPHRASE=
SFTP_REMOTE_DIR=