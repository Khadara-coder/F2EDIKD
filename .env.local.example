# ─────────────────────────────────────────────────────────────────────────────
# Configuration de développement LOCAL — copiez ce fichier en `.env.local`
# (`.env.local` est ignoré par git). Objectif : reproduire en local le
# comportement de l'app sur Databricks (auth, rôles, LLM, chemins).
# ─────────────────────────────────────────────────────────────────────────────

# ── Identité & rôles ─────────────────────────────────────────────────────────
# Identité "dev" injectée quand aucun header SSO n'est présent (local uniquement).
# Elle passe par le vrai RBAC : mettez votre email pour être reconnu admin.
DEV_ACTOR=dik1dy@bosch.com

# Modèle 2 rôles: admin explicite, tous les autres utilisateurs authentifiés sont adv.
APP_ADMIN_USERS=dik1dy@bosch.com,dik1dy,khadara

# Auth : laissez vide pour utiliser le défaut intelligent
# (true si DEV_ACTOR est défini, false sinon). Forcez si besoin.
# APP_REQUIRE_AUTH=true

# ── LLM (extraction IA) ──────────────────────────────────────────────────────
# Profil Databricks CLI déjà authentifié (databricks auth login). Permet à
# l'endpoint `databricks-gpt-oss-120b` de répondre en local comme sur Databricks.
DATABRICKS_CONFIG_PROFILE=Khadara
DATABRICKS_HOST=https://adb-5555213114570927.7.azuredatabricks.net
DATABRICKS_MODEL_ENDPOINT=databricks-gpt-oss-120b
# Alternative : token personnel (déconseillé, préférez le profil ci-dessus)
# DATABRICKS_TOKEN=

# ── EDI (identique à Databricks) ─────────────────────────────────────────────
EDIFACT_PROFILE=ELM_STANDARD
EDIFACT_SYNTAX=D96A
UNB_SENDER_GLN=4399901876613
UNB_RECEIVER_GLN=3015981600108

# ── Chemins locaux (fallback automatique vers ./data si non défini) ──────────
# Laissez commenté : server.py bascule seul vers ./data en local.
# MASTERDATA_RUNTIME_DIR=data/masterdata
# OUTBOX_DIR=data/outbox
# LOG_DIR=data/logs
# PDF_STORAGE_DIR=data/pdf
# DB_PATH=data/edifact_standalone.db
