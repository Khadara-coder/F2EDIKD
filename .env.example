# ============================================================
# File2EDI + EDIFACT — environment template
# Copy to .env and fill in secrets before running
# ============================================================

# ── API runtime ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DATABRICKS_APP_PORT=8000
LOG_LEVEL=INFO

# ── File2EDI UI (React SPA in frontend/dist) ─────────────────────────────────
VITE_API_PROXY=http://localhost:8000

# ── Storage paths ─────────────────────────────────────────────
DATA_DIR=./data
DB_PATH=./data/edifact_standalone.db
INTAKE_DIR=./data/intake
PROCESSED_DIR=./data/processed
REJECT_DIR=./data/reject
OUTBOX_DIR=./data/outbox
LOG_DIR=./data/logs

# ── Master data ───────────────────────────────────────────────
MASTER_DATA_DIR=./data/masterdata
MASTERDATA_SOURCE_DIR=./data/masterdata
MASTERDATA_RUNTIME_DIR=./data/masterdata

# ── Worker (standalone orchestrator — docker-compose.yml) ───
WORKER_POLL_SECONDS=5

# ── Databricks SQL Warehouse (backend only — never expose to browser)
DATABRICKS_SERVER_HOSTNAME=
DATABRICKS_HTTP_PATH=
DATABRICKS_TOKEN=
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=file2edi
DATABRICKS_WAREHOUSE_ID=
DATABRICKS_PERSIST_PATH=
DATABRICKS_MODEL_ENDPOINT=databricks-gpt-oss-120b

# ── SFTP delivery ─────────────────────────────────────────────
SFTP_ENABLED=false
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=
SFTP_PRIVATE_KEY_PASSPHRASE=
SFTP_REMOTE_DIR=

# ── Notifications ─────────────────────────────────────────────
REJECTION_SEND_EMAIL=false
SMTP_HOST=

# ── Local Docker mock (skip Databricks SQL when true) ─────────
MOCK_MODE=false
